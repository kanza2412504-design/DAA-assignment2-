import java.util.*;
class BoyerMoore {

    static final int ALPHABET_SIZE = 256;
    // Bad Character Heuristic Table
    private static int[] buildBadCharTable(String pattern) {
        int[] badChar = new int[ALPHABET_SIZE];
        Arrays.fill(badChar, -1);
        for (int i = 0; i < pattern.length(); i++) {
            badChar[(int) pattern.charAt(i)] = i;
        }
        return badChar;
    }
    // Good Suffix Heuristic - shift table
    private static int[] buildGoodSuffixTable(String pattern) {
        int m = pattern.length();
        int[] shift = new int[m + 1];
        int[] border = new int[m + 1];
        Arrays.fill(shift, m); // default shift = pattern length
        // Phase 1: compute border positions
        int i = m, j = m + 1;
        border[i] = j;
        while (i > 0) {
            while (j <= m && pattern.charAt(i - 1) != pattern.charAt(j - 1)) {
                if (shift[j] == m) shift[j] = j - i;
                j = border[j];
            }
            i--;
            j--;
            border[i] = j;
        }
        // Phase 2: handle case where suffix appears at start
        j = border[0];
        for (i = 0; i <= m; i++) {
            if (shift[i] == m) shift[i] = j;
            if (i == j) j = border[j];
        }
        return shift;
    }
    // Main Boyer-Moore search
    public static void search(String text, String pattern) {
        int n = text.length();
        int m = pattern.length();
        int[] badChar  = buildBadCharTable(pattern);
        int[] goodSuffix = buildGoodSuffixTable(pattern);
        System.out.println("Text:    \"" + text + "\"");
        System.out.println("Pattern: \"" + pattern + "\"");
        System.out.println();
        List<Integer> occurrences = new ArrayList<>();
        int comparisons = 0;
        int shift = 0;
        while (shift <= n - m) {
            int j = m - 1;
            // Match from right to left
            while (j >= 0 && pattern.charAt(j) == text.charAt(shift + j)) {
                comparisons++;
                j--;
            }
            if (j < 0) {
                // Pattern found
                occurrences.add(shift);
                System.out.println("Pattern found at index: " + shift
                        + " => \"..." + text.substring(shift, shift + m) + "...\"");
                shift += goodSuffix[0];
            } else {
                comparisons++;
                // Calculate shifts from both heuristics
                int badCharShift  = j - badChar[(int) text.charAt(shift + j)];
                int goodSufShift  = goodSuffix[j + 1];

                int moveBy = Math.max(badCharShift, goodSufShift);
                System.out.println("Mismatch at text[" + (shift + j) + "] = '"
                        + text.charAt(shift + j) + "' vs pattern[" + j + "] = '"
                        + pattern.charAt(j) + "'  => shifting by " + moveBy);
                shift += moveBy;
            }
        }
        System.out.println("\n--- Results ---");
        if (occurrences.isEmpty()) {
            System.out.println("Pattern NOT found in text.");
        } else {
            System.out.println("Pattern found " + occurrences.size()
                    + " time(s) at index/indices: " + occurrences);
        }
        System.out.println("Total character comparisons: " + comparisons);
    }
    public static void main(String[] args) {
        String text    = "Insertion sort typically has a smaller constant factor than merge sort";
        String pattern = "sort";
        System.out.println("=== Boyer-Moore String Matching Algorithm ===\n");
        search(text, pattern);
    }
}
